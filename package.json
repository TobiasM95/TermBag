{
  "name": "termbag",
  "version": "0.1.0",
  "private": true,
  "author": "TobiasM95",
  "description": "Windows-first terminal workspace with lazy restore and local persistence.",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "pnpm run rebuild:native",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,node-pty",
    "dev": "concurrently -k --success first \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 dist-electron/main/index.js dist-electron/preload/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main/index.js",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "preview": "cross-env NODE_ENV=production electron dist-electron/main/index.js",
    "test": "vitest run",
    "package:win": "pnpm build && electron-builder --win nsis portable && node scripts/patch-windows-artifacts.mjs",
    "package:win:dir": "pnpm build && electron-builder --win dir && node scripts/patch-windows-artifacts.mjs"
  },
  "build": {
    "appId": "com.tobiasm95.termbag",
    "productName": "TermBag",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TermBag"
    },
    "portable": {
      "artifactName": "TermBag.exe"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "node-pty",
      "esbuild"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.6.2",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
